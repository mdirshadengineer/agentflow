{
	"name": "@mdirshadengineer/agentflow-nodes",
	"type": "module",
	"version": "0.1.0",
	"description": "AgentFlow built-in node manifests and executors.",
	"license": "Apache-2.0",
	"author": {
		"name": "mdirshadengineer",
		"email": "mdirshadengineer+github@gmail.com",
		"url": "https://mdirshad.vercel.app"
	},
	"repository": {
		"directory": "packages/nodes",
		"type": "git"
	},
	"engines": {
		"node": ">=22.16"
	},
	"exports": {
		".": {
			"types": "./src/index.ts",
			"import": "./src/index.ts"
		}
	},
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"files": [
		"dist",
		"README.md",
		"package.json"
	],
	"scripts": {
		"build": "shx rm -rf dist && tsc -b tsconfig.build.json",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check",
		"format": "biome format --write",
		"typecheck": "tsc --noEmit",
		"clean": "shx rm -rf node_modules .turbo dist"
	},
	"dependencies": {
		"@mdirshadengineer/agentflow-core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "25.6.0",
		"tsx": "4.21.0",
		"typescript": "6.0.3",
		"vitest": "3.2.4"
	}
}
