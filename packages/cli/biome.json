{
	"$schema": "../../node_modules/@biomejs/biome/configuration_schema.json",
	"extends": ["../../biome.json"],
	"root": false,
	"files": {
		"includes": ["**/*.ts", "!node_modules", "!dist"]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"bracketSameLine": true,
		"bracketSpacing": true
	},
	"javascript": {
		"assist": {
			"enabled": true
		},
		"formatter": {
			"enabled": true,
			"indentStyle": "tab",
			"bracketSameLine": true,
			"bracketSpacing": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noEnum": "error"
			}
		}
	}
}
