{
	"$schema": "../../node_modules/@biomejs/biome/configuration_schema.json",
	"extends": ["../../biome.json"],
	"root": false,
	"files": {
		"includes": ["**/*.ts", "!node_modules", "!dist"]
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineEnding": "lf",
		"lineWidth": 80,
		"attributePosition": "auto",
		"bracketSameLine": false,
		"bracketSpacing": true,
		"expand": "auto",
		"useEditorconfig": false,
		"includes": [
			"**",
			"!**/node_modules/",
			"!**/coverage/",
			"!**/.pnpm-store/",
			"!**/pnpm-lock.yaml",
			"!**/package-lock.json",
			"!**/pnpm-lock.yaml",
			"!**/yarn.lock"
		]
	},
	"javascript": {
		"assist": {
			"enabled": true
		},
		"formatter": {
			"enabled": true,
			"indentStyle": "tab",
			"bracketSameLine": true,
			"bracketSpacing": true
		}
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noEnum": "error"
			}
		}
	}
}
