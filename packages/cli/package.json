{
	"name": "@mdirshadengineer/agentflow-cli",
	"type": "module",
	"version": "0.2.1",
	"description": "AgentFlow CLI - A powerful command-line interface for managing and orchestrating your agent-based workflows with ease.",
	"license": "Apache-2.0",
	"bin": {
		"agf": "bin/agentflow",
		"agentflow": "bin/agentflow"
	},
	"publishConfig": {
		"access": "public"
	},
	"author": {
		"name": "mdirshadengineer",
		"email": "mdirshadengineer+github@gmail.com",
		"url": "https://mdirshad.vercel.app"
	},
	"repository": {
		"directory": "packages/cli",
		"type": "git"
	},
	"engines": {
		"node": ">=22.16"
	},
	"files": ["dist", "bin", "README.md", "CHANGELOG.md", "package.json"],
	"scripts": {
		"start": "node ./bin/agentflow",
		"dev": "tsx watch src/dev/main.ts",
		"build-ui": "pnpm --filter agentflow-platform-ui-app ui-build",
		"compile-cli": "shx rm -rf dist && tsc -b tsconfig.build.json",
		"sync-ui": "shx rm -rf dist/ui && shx mkdir -p dist/ui && shx cp -r ../../app/dist/. dist/ui",
		"build": "pnpm run build-ui && pnpm run compile-cli && pnpm run sync-ui",
		"test": "vitest run",
		"test:watch": "vitest",
		"lint": "biome check",
		"format": "biome format --write",
		"typecheck": "tsc --noEmit",
		"clean": "shx rm -rf node_modules .turbo dist"
	},
	"dependencies": {
		"@fastify/autoload": "6.3.1",
		"@fastify/cookie": "11.0.2",
		"@fastify/http-proxy": "11.4.4",
		"@fastify/jwt": "10.0.0",
		"@fastify/static": "9.1.3",
		"arktype": "2.2.0",
		"bcryptjs": "3.0.3",
		"better-sqlite3": "12.9.0",
		"drizzle-orm": "0.45.2",
		"fastify": "5.8.5",
		"node-cron": "4.2.1",
		"reflect-metadata": "0.2.2",
		"semver": "7.7.4",
		"source-map-support": "0.5.21",
		"tsyringe": "4.10.0"
	},
	"devDependencies": {
		"@types/bcryptjs": "3.0.0",
		"@types/better-sqlite3": "7.6.13",
		"@types/node": "25.6.0",
		"@types/node-cron": "3.0.11",
		"drizzle-kit": "0.31.10",
		"tsx": "4.21.0",
		"typescript": "6.0.3",
		"vitest": "3.2.4"
	}
}
