{
	"$schema": "./node_modules/turbo/schema.json",
	"ui": "tui",
	"tasks": {
		"dev": {
			"cache": false,
			"persistent": true
		},
		"test": {
			"outputs": ["coverage/**"],
			"dependsOn": []
		},
		"lint": {},
		"start": {
			"cache": false,
			"persistent": true
		},
		"build": {
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**"],
			"dependsOn": ["^build"]
		},
		"clean": {
			"cache": false
		},
		"format": {}
	}
}
